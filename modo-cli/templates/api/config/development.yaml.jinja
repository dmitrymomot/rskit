server:
  port: 3000
  secret_key: ${SECRET_KEY:-{{ project_name }}-dev-secret-change-in-production}
  show_banner: true
database:
{%- if db_driver == "sqlite" %}
  sqlite:
    path: ${DATABASE_URL:-data/main.db}
{%- else %}
  postgres:
    url: ${DATABASE_URL:-postgres://postgres:postgres@localhost:5432/{{ project_name }}}
{%- endif %}
  max_connections: 5
  min_connections: 1
