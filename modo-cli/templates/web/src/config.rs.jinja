use modo::AppConfig;
use modo_db::DatabaseConfig;
use modo_email::EmailConfig;
use modo_jobs::JobsConfig;
use modo_session::SessionConfig;
use modo_upload::UploadConfig;
use serde::Deserialize;

#[derive(Default, Deserialize)]
pub(crate) struct Config {
    #[serde(flatten)]
    pub(crate) core: AppConfig,
    pub(crate) database: DatabaseConfig,
{%- if db_driver == "sqlite" %}
    pub(crate) jobs_database: DatabaseConfig,
{%- endif %}
    #[serde(default)]
    pub(crate) jobs: JobsConfig,
    #[serde(default)]
    pub(crate) session: SessionConfig,
    #[serde(default)]
    pub(crate) email: EmailConfig,
    #[serde(default)]
    pub(crate) upload: UploadConfig,
}

#[cfg(feature = "sentry")]
impl modo::SentryConfigProvider for Config {
    fn sentry_config(&self) -> Option<&modo::SentryConfig> {
        self.core.sentry_config()
    }
}
