server:
  port: 3000
  secret_key: ${SECRET_KEY:-{{ project_name }}-dev-secret-change-in-production}
  show_banner: true
  http:
    timeout: 3600
  static_files:
    prefix: /static
templates:
  path: templates/app
database:
{%- if db_driver == "sqlite" %}
  url: ${DATABASE_URL:-sqlite://data/main.db?mode=rwc}
{%- else %}
  url: ${DATABASE_URL:-postgres://{{ project_name }}:{{ project_name }}@localhost:5432/{{ project_name }}_development}
{%- endif %}
  max_connections: 5
  min_connections: 1
{%- if db_driver == "sqlite" %}
jobs_database:
  url: ${JOBS_DATABASE_URL:-sqlite://data/jobs.db?mode=rwc}
  max_connections: 5
  min_connections: 1
{%- endif %}
jobs:
  queues:
    - name: default
      concurrency: 4
    - name: email
      concurrency: 2
cookie:
  secure: false
session:
  session_ttl_secs: 2592000
  validate_fingerprint: true
  max_sessions_per_user: 10
# Mailpit Web UI: http://localhost:8025
email:
  templates_path: templates/emails
  default_from_name: {{ project_name }}
  default_from_email: noreply@localhost
  cache_templates: false
  smtp:
    host: localhost
    port: 1025
    security: none
i18n:
  path: locales
  default_lang: en
{%- if s3 %}
upload:
  backend: s3
  s3:
    bucket: uploads
    region: us-east-1
    endpoint: http://localhost:9000
    access_key_id: admin
    secret_access_key: admin123
{%- else %}
upload:
  backend: local
  path: ./uploads
{%- endif %}
