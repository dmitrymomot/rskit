server:
  port: ${PORT:-8080}
  secret_key: ${SECRET_KEY}
  show_banner: false
  static_files:
    prefix: /static
templates:
  path: templates/app
database:
  url: ${DATABASE_URL}
  max_connections: 20
  min_connections: 5
{%- if db_driver == "sqlite" %}
jobs_database:
  url: ${JOBS_DATABASE_URL}
  max_connections: 10
  min_connections: 2
{%- endif %}
jobs:
  queues:
    - name: default
      concurrency: 4
    - name: email
      concurrency: 2
cookie:
  secure: true
session:
  session_ttl_secs: 2592000
  validate_fingerprint: true
  max_sessions_per_user: 10
email:
  templates_path: templates/emails
  default_from_name: ${EMAIL_FROM_NAME}
  default_from_email: ${EMAIL_FROM_ADDRESS}
  resend:
    api_key: ${RESEND_API_KEY}
i18n:
  path: locales
  default_lang: en
upload:
  backend: s3
  s3:
    bucket: ${STORAGE_BUCKET}
    region: ${STORAGE_REGION}
    endpoint: ${STORAGE_ENDPOINT}
    access_key_id: ${STORAGE_ACCESS_KEY_ID}
    secret_access_key: ${STORAGE_SECRET_ACCESS_KEY}
