# Run dev server with auto-reload
dev: docker-up css
	cargo watch -x run

# Release build
build:
	cargo build --release

# Format code
fmt:
	cargo fmt --all

# Check formatting (CI-friendly, fails on diff)
fmt-check:
	cargo fmt --all -- --check

# Lint with clippy
lint:
	cargo clippy --workspace --all-targets --all-features -- -D warnings

# Run tests
test:
	cargo test --workspace --all-targets

# Format check + lint + test
check: fmt-check lint test

# Build Tailwind CSS
css:
	#!/usr/bin/env bash
	set -euo pipefail
	if ! command -v tailwindcss &> /dev/null; then
		echo "Error: tailwindcss CLI not found."
		echo "Install it from: https://tailwindcss.com/docs/installation/tailwind-cli"
		exit 1
	fi
	tailwindcss -i assets/src/app.css -o static/css/app.css --minify

# Download frontend JS dependencies
assets-download:
	#!/usr/bin/env bash
	set -euo pipefail
	mkdir -p static/js
	curl -sL https://unpkg.com/htmx.org@2.0.8/dist/htmx.min.js -o static/js/htmx.min.js
	curl -sL https://unpkg.com/htmx.org@2.0.8/dist/ext/sse.js -o static/js/htmx-sse.js
	curl -sL https://unpkg.com/alpinejs@3.15.8/dist/cdn.min.js -o static/js/alpine.min.js
	curl -sL "https://cdn.jsdelivr.net/npm/@tailwindplus/elements@1" | sed '/^\/\/# sourceMappingURL=/d' > "static/js/elements.min.js"
	echo "Assets downloaded successfully."

# Start dev services (starts Docker if needed)
docker-up:
	#!/usr/bin/env bash
	set -euo pipefail
	if ! docker info &>/dev/null 2>&1; then
	    echo "Docker is not running. Starting..."
	    if [[ "$(uname)" == "Darwin" ]]; then
	        open -a Docker
	    else
	        sudo systemctl start docker 2>/dev/null || sudo service docker start 2>/dev/null || true
	    fi
	    for i in $(seq 1 30); do
	        docker info &>/dev/null 2>&1 && break
	        sleep 1
	    done
	    if ! docker info &>/dev/null 2>&1; then
	        echo "Error: Docker failed to start. Please start it manually."
	        exit 1
	    fi
	    echo "Docker is ready."
	fi
	docker compose up -d

# Stop dev services
docker-down:
	docker compose down
