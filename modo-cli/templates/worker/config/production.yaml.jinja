server:
  port: ${PORT:-8080}
  secret_key: ${SECRET_KEY}
  show_banner: false
database:
{%- if db_driver == "sqlite" %}
  sqlite:
    path: ${DATABASE_URL}
{%- else %}
  postgres:
    url: ${DATABASE_URL}
{%- endif %}
  max_connections: 20
  min_connections: 5
{%- if db_driver == "sqlite" %}
jobs_database:
  sqlite:
    path: ${JOBS_DATABASE_URL}
  max_connections: 10
  min_connections: 2
{%- endif %}
jobs:
  queues:
    - name: default
      concurrency: 4
sentry:
  dsn: ${SENTRY_DSN}
  environment: production
  traces_sample_rate: 0.2
