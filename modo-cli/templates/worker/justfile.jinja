# Run dev server with auto-reload
{% if db_driver == "postgres" %}
dev: docker-up
	cargo watch -x run
{% else %}
dev:
	cargo watch -x run
{% endif %}

# Release build
build:
	cargo build --release

# Format code
fmt:
	cargo fmt

# Run clippy
lint:
	cargo clippy -- -D warnings

# Run tests
test:
	cargo test

# Format check + lint + test
check:
	cargo fmt -- --check
	cargo clippy -- -D warnings
	cargo test
{% if db_driver == "postgres" %}

# Start Postgres container
docker-up:
	docker compose up -d

# Stop Postgres container
docker-down:
	docker compose down
{% endif %}
