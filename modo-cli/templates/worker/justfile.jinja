set dotenv-load

# Run dev server with auto-reload
{%- if db_driver == "postgres" %}
dev: docker-up
	cargo watch -x run
{%- else %}
dev:
	cargo watch -x run
{%- endif %}

# Release build
build:
	cargo build --release

# Format code
fmt:
	cargo fmt --all

# Check formatting (CI-friendly, fails on diff)
fmt-check:
	cargo fmt --all -- --check

# Lint with clippy
lint:
	cargo clippy --workspace --all-targets --all-features -- -D warnings

# Run tests
test:
	cargo test --workspace --all-targets

# Format check + lint + test
check: fmt-check lint test
{%- if db_driver == "postgres" %}

# Start dev services (starts Docker if needed)
docker-up:
	#!/usr/bin/env bash
	set -euo pipefail
	if ! docker info &>/dev/null 2>&1; then
	    echo "Docker is not running. Starting..."
	    if [[ "$(uname)" == "Darwin" ]]; then
	        open -a Docker
	    else
	        sudo systemctl start docker 2>/dev/null || sudo service docker start 2>/dev/null || true
	    fi
	    for i in $(seq 1 30); do
	        docker info &>/dev/null 2>&1 && break
	        sleep 1
	    done
	    if ! docker info &>/dev/null 2>&1; then
	        echo "Error: Docker failed to start. Please start it manually."
	        exit 1
	    fi
	    echo "Docker is ready."
	fi
	docker compose up -d

# Stop dev services
docker-down:
	docker compose down
{%- endif %}
