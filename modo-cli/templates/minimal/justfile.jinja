# Run dev server with auto-reload
dev:
	cargo watch -x run

# Release build
build:
	cargo build --release

# Format code
fmt:
	cargo fmt

# Run clippy
lint:
	cargo clippy -- -D warnings

# Run tests
test:
	cargo test

# Format check + lint + test
check:
	cargo fmt -- --check
	cargo clippy -- -D warnings
	cargo test
