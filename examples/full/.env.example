APP_ENV=development

# Server
PORT=8080

# Cookie signing (min 64 chars)
COOKIE_SECRET=change-me-in-production-at-least-64-bytes-long-secret-key-here!!

# S3-compatible storage (RustFS)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=admin
S3_SECRET_KEY=admin123
S3_REGION=us-east-1

# SMTP (Mailpit)
SMTP_HOST=localhost
SMTP_PORT=1025

# Sentry (optional)
SENTRY_DSN=

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT
JWT_SECRET=change-me-in-production-at-least-64-bytes-long-jwt-secret-key-here!!!!!
